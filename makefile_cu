CC = gcc
CXX = g++
NVCC = nvcc

OUT_DIR ?= ./bin-cu
SRC_DIR ?= ./src

GMP_DIR ?= /usr/local
GMP_INCLUDE_DIR ?= $(GMP_DIR)/include
GMP_LIB_DIR ?= $(GMP_DIR)/lib
GWNUM_DIR ?= /usr/local/gwnum

PRIMESIEVE_INCLUDE_DIR ?= /usr/local/include/primesieve
SIEVER_FLAGS ?= -DCUTRIALDIVE_HAS_PRIMESIEVE -I$(PRIMESIEVE_INCLUDE_DIR)
PRIMESIEVE_LIB_FLAGS ?= -L/usr/lib/x86_64-linux-gnu/ -lprimesieve

OFLAG ?= -O3
ADDITIONAL_OFLAG ?= -march=native -mtune=native

CFLAGS = -fopenmp -fPIC $(OFLAG) $(ADDITIONAL_OFLAG) -I$(GMP_INCLUDE_DIR) -I$(GWNUM_DIR) $(SIEVER_FLAGS)
CXXFLAGS = -fopenmp -fPIC $(OFLAG) $(ADDITIONAL_OFLAG) -I$(GMP_INCLUDE_DIR) -I$(GWNUM_DIR) $(SIEVER_FLAGS)
NVCCFLAGS = -std=c++20 $(OFLAG) -Xcompiler "$(OFLAG) $(ADDITIONAL_OFLAG)" -I$(GMP_INCLUDE_DIR) -I$(GWNUM_DIR) $(SIEVER_FLAGS)


OBJS = $(OUT_DIR)/gw_utility.o \
       $(OUT_DIR)/cutrialdiv.o \
	   $(OUT_DIR)/prp.o \
	   $(OUT_DIR)/modular_arithmetic_detail.o \
	   $(OUT_DIR)/autotests.o

all: $(OUT_DIR) $(OUT_DIR)/cutrialdive

$(OUT_DIR):
	mkdir -p $(OUT_DIR)

$(OUT_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

$(OUT_DIR)/%.o: $(SRC_DIR)/%.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

$(OUT_DIR)/%.o: $(SRC_DIR)/%.cu
	$(NVCC) $(NVCCFLAGS) -c -o $@ $<

$(OUT_DIR)/cutrialdive: $(OBJS)
	$(NVCC) -o $@ $^ -Xcompiler "-fopenmp" $(PRIMESIEVE_LIB_FLAGS) -L$(GMP_LIB_DIR) -L$(GWNUM_DIR) -l:gwnum.a -lgmp -ldl

clean:
	rm -f $(OUT_DIR)/cutrialdive
	rm -f $(OBJS)


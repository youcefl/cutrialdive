CC = gcc
CXX = g++
NVCC = nvcc

GMP_DIR ?= /usr/local
GWNUM_DIR ?= /usr/local/gwnum
OUT_DIR ?= ./bin-cu

PRIMESIEVE_INCLUDE_DIR ?= 
SIEVER_FLAGS ?= -DCUTRIALDIVE_HAS_PRIMESIEVE -I$(PRIMESIEVE_INCLUDE_DIR)
PRIMESIEVE_LIB_FLAGS ?= -L/usr/lib/x86_64-linux-gnu/ -lprimesieve

CFLAGS = -fopenmp -fPIC -O3 -I$(GMP_DIR)/include -I$(GWNUM_DIR) $(SIEVER_FLAGS)
CXXFLAGS = -fopenmp -fPIC -O3 -I$(GMP_DIR)/include -I$(GWNUM_DIR) $(SIEVER_FLAGS)
NVCCFLAGS = -std=c++20 -O3 -I$(GMP_DIR)/include -I$(GWNUM_DIR) $(SIEVER_FLAGS)


OBJS = $(OUT_DIR)/gw_utility.o \
       $(OUT_DIR)/cutrialdiv.o \
	   $(OUT_DIR)/prp.o \
	   $(OUT_DIR)/modular_arithmetic_detail.o \
	   $(OUT_DIR)/autotests.o

all: $(OUT_DIR) $(OUT_DIR)/cutrialdive

$(OUT_DIR):
	mkdir -p $(OUT_DIR)

$(OUT_DIR)/%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

$(OUT_DIR)/%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

$(OUT_DIR)/%.o: %.cu
	$(NVCC) $(NVCCFLAGS) -c -o $@ $<

$(OUT_DIR)/cutrialdive: $(OBJS)
	$(NVCC) -o $@ $^ -Xcompiler "-fopenmp -O3 -march=native -mtune=native" $(PRIMESIEVE_LIB_FLAGS) -L$(GMP_DIR)/lib -L$(GWNUM_DIR) -l:gwnum.a -lgmp -ldl

clean:
	rm -f $(OUT_DIR)/cutrialdive
	rm -f $(OBJS)

